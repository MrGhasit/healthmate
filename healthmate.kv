#:kivy 2.0
#:import get_color_from_hex kivy.utils.get_color_from_hex
#:import SlideTransition kivy.uix.screenmanager.SlideTransition
#:import dp kivy.metrics.dp
#:import get_day_index main.get_day_index
#:import LFK_PLAN main.LFK_PLAN
#:import DIET_PLAN main.DIET_PLAN

# ════════════════════════════════════════
#  ОБЩИЙ ФОН
# ════════════════════════════════════════
<Screen>:
    canvas.before:
        Color:
            rgba: get_color_from_hex('#1A2535')
        Rectangle:
            size: self.size
            pos: self.pos

# ════════════════════════════════════════
#  ГЛАВНЫЙ ЭКРАН (заставка)
# ════════════════════════════════════════
<MainScreen>:
    BoxLayout:
        orientation: 'vertical'
        padding: [dp(30), dp(60), dp(30), dp(40)]
        spacing: dp(20)

        BoxLayout:
            size_hint: None, None
            size: dp(90), dp(90)
            pos_hint: {'center_x': 0.5}
            canvas.before:
                Color:
                    rgba: get_color_from_hex('#6BCB77')
                Ellipse:
                    size: dp(90), dp(90)
                    pos: self.pos
            Label:
                text: 'HM'
                font_size: dp(28)
                bold: True
                color: get_color_from_hex('#FFFFFF')
                halign: 'center'
                valign: 'middle'

        Label:
            text: 'HealthMate'
            font_size: dp(32)
            bold: True
            color: get_color_from_hex('#FFFFFF')
            halign: 'center'

        Label:
            text: 'Диетотерапия и ЛФК'
            font_size: dp(16)
            color: get_color_from_hex('#A8C5DA')
            halign: 'center'

        Label:
            text: root.date_text
            font_size: dp(15)
            bold: True
            color: get_color_from_hex('#FFD93D')
            halign: 'center'

        Widget:
            size_hint_y: None
            height: dp(20)

        Button:
            text: 'Начать'
            size_hint: 0.75, None
            height: dp(56)
            pos_hint: {'center_x': 0.5}
            background_normal: ''
            background_color: get_color_from_hex('#6BCB77')
            color: get_color_from_hex('#FFFFFF')
            font_size: dp(18)
            bold: True
            on_release: root.manager.current = 'login'

        Widget:

# ════════════════════════════════════════
#  ЭКРАН ВХОДА
# ════════════════════════════════════════
<LoginScreen>:
    BoxLayout:
        orientation: 'vertical'
        padding: [dp(28), dp(70), dp(28), dp(50)]
        spacing: dp(18)

        Label:
            text: 'Добро пожаловать!'
            font_size: dp(26)
            bold: True
            color: get_color_from_hex('#FFD93D')
            halign: 'center'
            size_hint_y: None
            height: dp(40)

        Label:
            text: 'Войдите или продолжите как гость'
            font_size: dp(14)
            color: get_color_from_hex('#A8C5DA')
            halign: 'center'
            size_hint_y: None
            height: dp(30)

        Widget:
            size_hint_y: None
            height: dp(20)

        Button:
            text: 'Войти'
            size_hint: 0.85, None
            height: dp(54)
            pos_hint: {'center_x': 0.5}
            background_normal: ''
            background_color: get_color_from_hex('#6BCB77')
            color: get_color_from_hex('#FFFFFF')
            font_size: dp(16)
            bold: True
            on_release: root.show_unavailable()

        Button:
            text: 'Регистрация'
            size_hint: 0.85, None
            height: dp(54)
            pos_hint: {'center_x': 0.5}
            background_normal: ''
            background_color: get_color_from_hex('#1B4D3E')
            color: get_color_from_hex('#6BCB77')
            font_size: dp(16)
            bold: True
            on_release: root.show_unavailable()

        Label:
            text: '- или -'
            font_size: dp(13)
            color: get_color_from_hex('#A8C5DA')
            halign: 'center'
            size_hint_y: None
            height: dp(30)

        Button:
            text: 'Продолжить как гость'
            size_hint: 0.85, None
            height: dp(54)
            pos_hint: {'center_x': 0.5}
            background_normal: ''
            background_color: get_color_from_hex('#FFD93D')
            color: get_color_from_hex('#333333')
            font_size: dp(15)
            bold: True
            on_release: root.guest_login()

        Widget:

# ════════════════════════════════════════
#  ГЛАВНЫЙ ЭКРАН ПРИЛОЖЕНИЯ
# ════════════════════════════════════════
<AppScreen>:
    BoxLayout:
        orientation: 'vertical'

        # Шапка
        BoxLayout:
            size_hint_y: None
            height: dp(62)
            padding: [dp(14), dp(8)]
            spacing: dp(12)
            canvas.before:
                Color:
                    rgba: get_color_from_hex('#0F1C2A')
                Rectangle:
                    size: self.size
                    pos: self.pos

            Button:
                size_hint: None, None
                size: dp(42), dp(42)
                pos_hint: {'center_y': 0.5}
                background_normal: ''
                background_color: get_color_from_hex('#6BCB77')
                color: get_color_from_hex('#FFFFFF')
                font_size: dp(16)
                bold: True
                text: 'Я'
                on_release: app.root.current = 'settings'

            BoxLayout:
                orientation: 'vertical'
                spacing: dp(1)
                Label:
                    text: 'HealthMate'
                    font_size: dp(19)
                    bold: True
                    color: get_color_from_hex('#FFD93D')
                    halign: 'left'
                    text_size: self.size
                    valign: 'bottom'
                Label:
                    text: root.date_text
                    font_size: dp(12)
                    color: get_color_from_hex('#A8C5DA')
                    halign: 'left'
                    text_size: self.size
                    valign: 'top'

        # Карточки
        ScrollView:
            BoxLayout:
                orientation: 'vertical'
                size_hint_y: None
                height: self.minimum_height
                padding: [dp(14), dp(14)]
                spacing: dp(10)

                # --- Карточка: Напоминания ---
                Button:
                    size_hint_y: None
                    height: dp(80)
                    background_normal: ''
                    background_color: get_color_from_hex('#1E3A5F')
                    color: get_color_from_hex('#FFFFFF')
                    on_release: app.root.current = 'reminder'
                    text: ''
                    canvas.after:
                        Color:
                            rgba: 1, 1, 1, 1
                        # Метка аббревиатуры
                    BoxLayout:
                        orientation: 'vertical'
                        padding: [dp(54), dp(10), dp(14), dp(10)]
                        spacing: dp(4)
                        pos: self.parent.pos
                        size: self.parent.size
                        Label:
                            text: 'Напоминания'
                            font_size: dp(16)
                            bold: True
                            color: get_color_from_hex('#FFFFFF')
                            halign: 'left'
                            text_size: self.size
                            valign: 'bottom'
                        Label:
                            text: '08:00  12:00  16:00  18:00  22:00'
                            font_size: dp(12)
                            color: get_color_from_hex('#A8C5DA')
                            halign: 'left'
                            text_size: self.size
                            valign: 'top'
                    Label:
                        text: 'РЖМ'
                        font_size: dp(11)
                        bold: True
                        color: get_color_from_hex('#A8C5DA')
                        pos: self.parent.x + dp(6), self.parent.y + dp(16)
                        size: dp(42), dp(42)
                        halign: 'center'
                        valign: 'middle'
                        canvas.before:
                            Color:
                                rgba: get_color_from_hex('#2A4A6F')
                            Ellipse:
                                pos: self.parent.x + dp(6), self.parent.y + dp(16)
                                size: dp(42), dp(42)

                # --- Карточка: Диетотерапия ---
                Button:
                    size_hint_y: None
                    height: dp(80)
                    background_normal: ''
                    background_color: get_color_from_hex('#1B4D3E')
                    color: get_color_from_hex('#FFFFFF')
                    on_release: root.open_diet_today()
                    text: ''
                    BoxLayout:
                        orientation: 'vertical'
                        padding: [dp(54), dp(10), dp(14), dp(10)]
                        spacing: dp(4)
                        pos: self.parent.pos
                        size: self.parent.size
                        Label:
                            text: 'Диетотерапия'
                            font_size: dp(16)
                            bold: True
                            color: get_color_from_hex('#FFFFFF')
                            halign: 'left'
                            text_size: self.size
                            valign: 'bottom'
                        Label:
                            text: f'День {get_day_index()+1} — нажмите чтобы увидеть меню'
                            font_size: dp(12)
                            color: get_color_from_hex('#A8C5DA')
                            halign: 'left'
                            text_size: self.size
                            valign: 'top'
                    Label:
                        text: 'ДТ'
                        font_size: dp(14)
                        bold: True
                        color: get_color_from_hex('#6BCB77')
                        pos: self.parent.x + dp(6), self.parent.y + dp(16)
                        size: dp(42), dp(42)
                        halign: 'center'
                        valign: 'middle'
                        canvas.before:
                            Color:
                                rgba: get_color_from_hex('#256040')
                            Ellipse:
                                pos: self.parent.x + dp(6), self.parent.y + dp(16)
                                size: dp(42), dp(42)

                # --- Карточка: ЛФК ---
                Button:
                    size_hint_y: None
                    height: dp(80)
                    background_normal: ''
                    background_color: get_color_from_hex('#3D1F5C')
                    color: get_color_from_hex('#FFFFFF')
                    on_release: root.open_lfk_today()
                    text: ''
                    BoxLayout:
                        orientation: 'vertical'
                        padding: [dp(54), dp(10), dp(14), dp(10)]
                        spacing: dp(4)
                        pos: self.parent.pos
                        size: self.parent.size
                        Label:
                            text: 'ЛФК'
                            font_size: dp(16)
                            bold: True
                            color: get_color_from_hex('#FFFFFF')
                            halign: 'left'
                            text_size: self.size
                            valign: 'bottom'
                        Label:
                            text: f'День {get_day_index()+1} | {LFK_PLAN[get_day_index()]["title"]}'
                            font_size: dp(12)
                            color: get_color_from_hex('#A8C5DA')
                            halign: 'left'
                            text_size: self.size
                            valign: 'top'
                    Label:
                        text: 'ЛФК'
                        font_size: dp(12)
                        bold: True
                        color: get_color_from_hex('#D8A8F0')
                        pos: self.parent.x + dp(6), self.parent.y + dp(16)
                        size: dp(42), dp(42)
                        halign: 'center'
                        valign: 'middle'
                        canvas.before:
                            Color:
                                rgba: get_color_from_hex('#52286E')
                            Ellipse:
                                pos: self.parent.x + dp(6), self.parent.y + dp(16)
                                size: dp(42), dp(42)

                # --- Карточка: Календарь ---
                Button:
                    size_hint_y: None
                    height: dp(80)
                    background_normal: ''
                    background_color: get_color_from_hex('#4A2C00')
                    color: get_color_from_hex('#FFFFFF')
                    on_release: app.root.current = 'calendar'
                    text: ''
                    BoxLayout:
                        orientation: 'vertical'
                        padding: [dp(54), dp(10), dp(14), dp(10)]
                        spacing: dp(4)
                        pos: self.parent.pos
                        size: self.parent.size
                        Label:
                            text: 'Календарь'
                            font_size: dp(16)
                            bold: True
                            color: get_color_from_hex('#FFFFFF')
                            halign: 'left'
                            text_size: self.size
                            valign: 'bottom'
                        Label:
                            text: 'Расписание диеты на 30 дней'
                            font_size: dp(12)
                            color: get_color_from_hex('#A8C5DA')
                            halign: 'left'
                            text_size: self.size
                            valign: 'top'
                    Label:
                        text: 'КАЛ'
                        font_size: dp(11)
                        bold: True
                        color: get_color_from_hex('#FFD93D')
                        pos: self.parent.x + dp(6), self.parent.y + dp(16)
                        size: dp(42), dp(42)
                        halign: 'center'
                        valign: 'middle'
                        canvas.before:
                            Color:
                                rgba: get_color_from_hex('#5E3800')
                            Ellipse:
                                pos: self.parent.x + dp(6), self.parent.y + dp(16)
                                size: dp(42), dp(42)

        # Нижняя навигация
        BoxLayout:
            size_hint_y: None
            height: dp(56)
            canvas.before:
                Color:
                    rgba: get_color_from_hex('#0F1C2A')
                Rectangle:
                    size: self.size
                    pos: self.pos

            Button:
                text: 'Режим'
                background_normal: ''
                background_color: 0, 0, 0, 0
                color: get_color_from_hex('#A8C5DA')
                font_size: dp(12)
                bold: True
                on_release: app.root.current = 'reminder'

            Button:
                text: 'Чат'
                background_normal: ''
                background_color: 0, 0, 0, 0
                color: get_color_from_hex('#A8C5DA')
                font_size: dp(12)
                bold: True
                on_release: app.root.current = 'community'

            Button:
                text: 'Главная'
                background_normal: ''
                background_color: 0, 0, 0, 0
                color: get_color_from_hex('#FFD93D')
                font_size: dp(12)
                bold: True
                on_release: app.root.current = 'app_screen'

            Button:
                text: 'Погода'
                background_normal: ''
                background_color: 0, 0, 0, 0
                color: get_color_from_hex('#A8C5DA')
                font_size: dp(12)
                bold: True
                on_release: app.root.current = 'weather'

            Button:
                text: 'Профиль'
                background_normal: ''
                background_color: 0, 0, 0, 0
                color: get_color_from_hex('#A8C5DA')
                font_size: dp(12)
                bold: True
                on_release: app.root.current = 'settings'

# ════════════════════════════════════════
#  НАПОМИНАНИЯ
# ════════════════════════════════════════
<ReminderScreen>:
    BoxLayout:
        orientation: 'vertical'

        BoxLayout:
            size_hint_y: None
            height: dp(56)
            padding: [dp(12), dp(8)]
            spacing: dp(10)
            canvas.before:
                Color:
                    rgba: get_color_from_hex('#0F1C2A')
                Rectangle:
                    size: self.size
                    pos: self.pos
            Button:
                size_hint_x: None
                width: dp(50)
                text: '<'
                font_size: dp(22)
                bold: True
                background_normal: ''
                background_color: get_color_from_hex('#1B4D3E')
                color: get_color_from_hex('#6BCB77')
                on_release: app.root.current = 'app_screen'
            Label:
                text: 'Напоминания'
                font_size: dp(20)
                bold: True
                color: get_color_from_hex('#FFD93D')
                halign: 'left'
                text_size: self.size
                valign: 'middle'

        ScrollView:
            BoxLayout:
                orientation: 'vertical'
                size_hint_y: None
                height: self.minimum_height
                padding: [dp(14), dp(14)]
                spacing: dp(10)

                Label:
                    text: 'Ежедневный режим питания и отдыха'
                    font_size: dp(13)
                    color: get_color_from_hex('#A8C5DA')
                    halign: 'center'
                    size_hint_y: None
                    height: dp(30)

                BoxLayout:
                    size_hint_y: None
                    height: dp(68)
                    spacing: dp(0)
                    padding: [dp(14), dp(8)]
                    canvas.before:
                        Color:
                            rgba: get_color_from_hex('#1B4D3E')
                        RoundedRectangle:
                            size: self.size
                            pos: self.pos
                            radius: [dp(12)]
                    Label:
                        text: '08:00'
                        font_size: dp(20)
                        bold: True
                        color: get_color_from_hex('#6BCB77')
                        size_hint_x: None
                        width: dp(90)
                        halign: 'center'
                        valign: 'middle'
                    BoxLayout:
                        orientation: 'vertical'
                        Label:
                            text: 'Завтрак'
                            font_size: dp(15)
                            bold: True
                            color: get_color_from_hex('#FFFFFF')
                            halign: 'left'
                            text_size: self.size
                            valign: 'bottom'
                        Label:
                            text: 'Время приёма пищи'
                            font_size: dp(12)
                            color: get_color_from_hex('#A8C5DA')
                            halign: 'left'
                            text_size: self.size
                            valign: 'top'

                BoxLayout:
                    size_hint_y: None
                    height: dp(68)
                    padding: [dp(14), dp(8)]
                    canvas.before:
                        Color:
                            rgba: get_color_from_hex('#1E3A5F')
                        RoundedRectangle:
                            size: self.size
                            pos: self.pos
                            radius: [dp(12)]
                    Label:
                        text: '12:00'
                        font_size: dp(20)
                        bold: True
                        color: get_color_from_hex('#A8C5DA')
                        size_hint_x: None
                        width: dp(90)
                        halign: 'center'
                        valign: 'middle'
                    BoxLayout:
                        orientation: 'vertical'
                        Label:
                            text: 'Обед'
                            font_size: dp(15)
                            bold: True
                            color: get_color_from_hex('#FFFFFF')
                            halign: 'left'
                            text_size: self.size
                            valign: 'bottom'
                        Label:
                            text: 'Основной приём пищи'
                            font_size: dp(12)
                            color: get_color_from_hex('#A8C5DA')
                            halign: 'left'
                            text_size: self.size
                            valign: 'top'

                BoxLayout:
                    size_hint_y: None
                    height: dp(68)
                    padding: [dp(14), dp(8)]
                    canvas.before:
                        Color:
                            rgba: get_color_from_hex('#3D1F5C')
                        RoundedRectangle:
                            size: self.size
                            pos: self.pos
                            radius: [dp(12)]
                    Label:
                        text: '16:00'
                        font_size: dp(20)
                        bold: True
                        color: get_color_from_hex('#D8A8F0')
                        size_hint_x: None
                        width: dp(90)
                        halign: 'center'
                        valign: 'middle'
                    BoxLayout:
                        orientation: 'vertical'
                        Label:
                            text: 'Полдник'
                            font_size: dp(15)
                            bold: True
                            color: get_color_from_hex('#FFFFFF')
                            halign: 'left'
                            text_size: self.size
                            valign: 'bottom'
                        Label:
                            text: 'Лёгкий перекус'
                            font_size: dp(12)
                            color: get_color_from_hex('#A8C5DA')
                            halign: 'left'
                            text_size: self.size
                            valign: 'top'

                BoxLayout:
                    size_hint_y: None
                    height: dp(68)
                    padding: [dp(14), dp(8)]
                    canvas.before:
                        Color:
                            rgba: get_color_from_hex('#4A2C00')
                        RoundedRectangle:
                            size: self.size
                            pos: self.pos
                            radius: [dp(12)]
                    Label:
                        text: '18:00'
                        font_size: dp(20)
                        bold: True
                        color: get_color_from_hex('#FFD93D')
                        size_hint_x: None
                        width: dp(90)
                        halign: 'center'
                        valign: 'middle'
                    BoxLayout:
                        orientation: 'vertical'
                        Label:
                            text: 'Ужин'
                            font_size: dp(15)
                            bold: True
                            color: get_color_from_hex('#FFFFFF')
                            halign: 'left'
                            text_size: self.size
                            valign: 'bottom'
                        Label:
                            text: 'Лёгкий ужин'
                            font_size: dp(12)
                            color: get_color_from_hex('#A8C5DA')
                            halign: 'left'
                            text_size: self.size
                            valign: 'top'

                BoxLayout:
                    size_hint_y: None
                    height: dp(68)
                    padding: [dp(14), dp(8)]
                    canvas.before:
                        Color:
                            rgba: get_color_from_hex('#162A3A')
                        RoundedRectangle:
                            size: self.size
                            pos: self.pos
                            radius: [dp(12)]
                    Label:
                        text: '22:00'
                        font_size: dp(20)
                        bold: True
                        color: get_color_from_hex('#FFFFFF')
                        size_hint_x: None
                        width: dp(90)
                        halign: 'center'
                        valign: 'middle'
                    BoxLayout:
                        orientation: 'vertical'
                        Label:
                            text: 'Сон'
                            font_size: dp(15)
                            bold: True
                            color: get_color_from_hex('#FFFFFF')
                            halign: 'left'
                            text_size: self.size
                            valign: 'bottom'
                        Label:
                            text: 'Время отдыха и восстановления'
                            font_size: dp(12)
                            color: get_color_from_hex('#A8C5DA')
                            halign: 'left'
                            text_size: self.size
                            valign: 'top'

# ════════════════════════════════════════
#  СООБЩЕСТВО
# ════════════════════════════════════════
<CommunityScreen>:
    BoxLayout:
        orientation: 'vertical'

        BoxLayout:
            size_hint_y: None
            height: dp(56)
            padding: [dp(12), dp(8)]
            spacing: dp(10)
            canvas.before:
                Color:
                    rgba: get_color_from_hex('#0F1C2A')
                Rectangle:
                    size: self.size
                    pos: self.pos
            Button:
                size_hint_x: None
                width: dp(50)
                text: '<'
                font_size: dp(22)
                bold: True
                background_normal: ''
                background_color: get_color_from_hex('#1B4D3E')
                color: get_color_from_hex('#6BCB77')
                on_release: app.root.current = 'app_screen'
            Label:
                text: 'К успеху! - чат'
                font_size: dp(20)
                bold: True
                color: get_color_from_hex('#FFD93D')
                halign: 'left'
                text_size: self.size
                valign: 'middle'

        ScrollView:
            id: chat_scroll
            BoxLayout:
                id: chat_box
                orientation: 'vertical'
                size_hint_y: None
                height: self.minimum_height
                padding: [dp(12), dp(12)]
                spacing: dp(8)

                Label:
                    text: 'Добро пожаловать в чат К успеху!'
                    font_size: dp(12)
                    color: get_color_from_hex('#A8C5DA')
                    halign: 'center'
                    size_hint_y: None
                    height: dp(28)

                BoxLayout:
                    size_hint_y: None
                    height: dp(66)
                    padding: [dp(12), dp(8)]
                    canvas.before:
                        Color:
                            rgba: get_color_from_hex('#1B4D3E')
                        RoundedRectangle:
                            size: self.size
                            pos: self.pos
                            radius: [dp(12)]
                    BoxLayout:
                        orientation: 'vertical'
                        Label:
                            text: 'Тренер Алина'
                            font_size: dp(11)
                            bold: True
                            color: get_color_from_hex('#6BCB77')
                            halign: 'left'
                            text_size: self.size
                            size_hint_y: None
                            height: dp(22)
                        Label:
                            text: 'Привет! Добро пожаловать в чат!'
                            font_size: dp(13)
                            color: get_color_from_hex('#FFFFFF')
                            halign: 'left'
                            text_size: self.size

                BoxLayout:
                    size_hint_y: None
                    height: dp(66)
                    padding: [dp(12), dp(8)]
                    canvas.before:
                        Color:
                            rgba: get_color_from_hex('#1E3A5F')
                        RoundedRectangle:
                            size: self.size
                            pos: self.pos
                            radius: [dp(12)]
                    BoxLayout:
                        orientation: 'vertical'
                        Label:
                            text: 'Михаил'
                            font_size: dp(11)
                            bold: True
                            color: get_color_from_hex('#A8C5DA')
                            halign: 'left'
                            text_size: self.size
                            size_hint_y: None
                            height: dp(22)
                        Label:
                            text: '2 недели по программе - уже лучше!'
                            font_size: dp(13)
                            color: get_color_from_hex('#FFFFFF')
                            halign: 'left'
                            text_size: self.size

                BoxLayout:
                    size_hint_y: None
                    height: dp(66)
                    padding: [dp(12), dp(8)]
                    canvas.before:
                        Color:
                            rgba: get_color_from_hex('#3D1F5C')
                        RoundedRectangle:
                            size: self.size
                            pos: self.pos
                            radius: [dp(12)]
                    BoxLayout:
                        orientation: 'vertical'
                        Label:
                            text: 'Светлана'
                            font_size: dp(11)
                            bold: True
                            color: get_color_from_hex('#D8A8F0')
                            halign: 'left'
                            text_size: self.size
                            size_hint_y: None
                            height: dp(22)
                        Label:
                            text: 'Сегодня выполнила всё ЛФК!'
                            font_size: dp(13)
                            color: get_color_from_hex('#FFFFFF')
                            halign: 'left'
                            text_size: self.size

        BoxLayout:
            size_hint_y: None
            height: dp(58)
            padding: [dp(12), dp(8)]
            spacing: dp(8)
            canvas.before:
                Color:
                    rgba: get_color_from_hex('#0F1C2A')
                Rectangle:
                    size: self.size
                    pos: self.pos
            TextInput:
                id: msg_input
                hint_text: 'Написать сообщение...'
                multiline: False
                background_color: get_color_from_hex('#1E2E3E')
                foreground_color: get_color_from_hex('#FFFFFF')
                hint_text_color: get_color_from_hex('#A8C5DA')
                cursor_color: get_color_from_hex('#6BCB77')
                font_size: dp(14)
                padding: [dp(10), dp(10)]
            Button:
                size_hint_x: None
                width: dp(60)
                text: '>'
                font_size: dp(22)
                bold: True
                background_normal: ''
                background_color: get_color_from_hex('#1B4D3E')
                color: get_color_from_hex('#FFFFFF')
                on_release: root.send_message(msg_input)

# ════════════════════════════════════════
#  ПОГОДА
# ════════════════════════════════════════
<WeatherScreen>:
    BoxLayout:
        orientation: 'vertical'

        BoxLayout:
            size_hint_y: None
            height: dp(56)
            padding: [dp(12), dp(8)]
            spacing: dp(10)
            canvas.before:
                Color:
                    rgba: get_color_from_hex('#0F1C2A')
                Rectangle:
                    size: self.size
                    pos: self.pos
            Button:
                size_hint_x: None
                width: dp(50)
                text: '<'
                font_size: dp(22)
                bold: True
                background_normal: ''
                background_color: get_color_from_hex('#1B4D3E')
                color: get_color_from_hex('#6BCB77')
                on_release: app.root.current = 'app_screen'
            Label:
                text: 'Погода'
                font_size: dp(20)
                bold: True
                color: get_color_from_hex('#FFD93D')
                halign: 'left'
                text_size: self.size
                valign: 'middle'

        BoxLayout:
            size_hint_y: None
            height: dp(52)
            padding: [dp(14), dp(6)]
            spacing: dp(8)
            canvas.before:
                Color:
                    rgba: get_color_from_hex('#0F1C2A')
                Rectangle:
                    size: self.size
                    pos: self.pos
            TextInput:
                id: city_inp
                text: 'Алматы'
                hint_text: 'Город...'
                multiline: False
                background_color: get_color_from_hex('#1E2E3E')
                foreground_color: get_color_from_hex('#FFFFFF')
                hint_text_color: get_color_from_hex('#A8C5DA')
                cursor_color: get_color_from_hex('#6BCB77')
                font_size: dp(15)
                padding: [dp(10), dp(10)]
            Button:
                size_hint_x: None
                width: dp(90)
                text: 'Найти'
                font_size: dp(14)
                bold: True
                background_normal: ''
                background_color: get_color_from_hex('#6BCB77')
                color: get_color_from_hex('#FFFFFF')
                on_release: root.fetch_weather(city_inp.text)

        ScrollView:
            BoxLayout:
                orientation: 'vertical'
                size_hint_y: None
                height: self.minimum_height
                padding: [dp(14), dp(14)]
                spacing: dp(14)

                Label:
                    text: 'Загрузка...'
                    font_size: dp(15)
                    color: get_color_from_hex('#A8C5DA')
                    halign: 'center'
                    size_hint_y: None
                    height: dp(40) if root.loading else dp(0)
                    opacity: 1 if root.loading else 0

                Label:
                    text: root.error_text
                    font_size: dp(14)
                    color: get_color_from_hex('#E74C3C')
                    halign: 'center'
                    size_hint_y: None
                    height: dp(40) if root.error_text else dp(0)
                    opacity: 1 if root.error_text else 0

                BoxLayout:
                    id: weather_cards
                    orientation: 'vertical'
                    size_hint_y: None
                    height: self.minimum_height
                    spacing: dp(12)

                Label:
                    text: 'Введите город и нажмите Найти\nдля прогноза на 2 дня'
                    font_size: dp(14)
                    color: get_color_from_hex('#A8C5DA')
                    halign: 'center'
                    size_hint_y: None
                    height: dp(70)

# ════════════════════════════════════════
#  КАЛЕНДАРЬ
# ════════════════════════════════════════
<CalendarScreen>:
    BoxLayout:
        orientation: 'vertical'

        BoxLayout:
            size_hint_y: None
            height: dp(56)
            padding: [dp(12), dp(8)]
            spacing: dp(10)
            canvas.before:
                Color:
                    rgba: get_color_from_hex('#0F1C2A')
                Rectangle:
                    size: self.size
                    pos: self.pos
            Button:
                size_hint_x: None
                width: dp(50)
                text: '<'
                font_size: dp(22)
                bold: True
                background_normal: ''
                background_color: get_color_from_hex('#1B4D3E')
                color: get_color_from_hex('#6BCB77')
                on_release: app.root.current = 'app_screen'
            Label:
                text: 'Расписание 30 дней'
                font_size: dp(20)
                bold: True
                color: get_color_from_hex('#FFD93D')
                halign: 'left'
                text_size: self.size
                valign: 'middle'

        BoxLayout:
            size_hint_y: None
            height: dp(28)
            padding: [dp(14), dp(2)]
            canvas.before:
                Color:
                    rgba: get_color_from_hex('#0F1C2A')
                Rectangle:
                    size: self.size
                    pos: self.pos
            Label:
                text: 'День'
                font_size: dp(11)
                bold: True
                color: get_color_from_hex('#6BCB77')
                size_hint_x: 0.22
                halign: 'left'
                text_size: self.size
            Label:
                text: 'Завтрак'
                font_size: dp(11)
                bold: True
                color: get_color_from_hex('#6BCB77')
                size_hint_x: 0.45
                halign: 'left'
                text_size: self.size
            Label:
                text: 'ЛФК'
                font_size: dp(11)
                bold: True
                color: get_color_from_hex('#6BCB77')
                size_hint_x: 0.33
                halign: 'right'
                text_size: self.size

        ScrollView:
            BoxLayout:
                id: calendar_grid
                orientation: 'vertical'
                size_hint_y: None
                height: self.minimum_height
                padding: [dp(10), dp(8)]
                spacing: dp(4)

# ════════════════════════════════════════
#  НАСТРОЙКИ / ПРОФИЛЬ
# ════════════════════════════════════════
<SettingsScreen>:
    BoxLayout:
        orientation: 'vertical'

        BoxLayout:
            size_hint_y: None
            height: dp(56)
            padding: [dp(12), dp(8)]
            spacing: dp(10)
            canvas.before:
                Color:
                    rgba: get_color_from_hex('#0F1C2A')
                Rectangle:
                    size: self.size
                    pos: self.pos
            Button:
                size_hint_x: None
                width: dp(50)
                text: '<'
                font_size: dp(22)
                bold: True
                background_normal: ''
                background_color: get_color_from_hex('#1B4D3E')
                color: get_color_from_hex('#6BCB77')
                on_release: root.go_back()
            Label:
                text: 'Профиль и настройки'
                font_size: dp(18)
                bold: True
                color: get_color_from_hex('#FFD93D')
                halign: 'left'
                text_size: self.size
                valign: 'middle'

        ScrollView:
            BoxLayout:
                orientation: 'vertical'
                size_hint_y: None
                height: self.minimum_height
                padding: [dp(14), dp(14)]
                spacing: dp(10)

                # Блок профиля
                BoxLayout:
                    size_hint_y: None
                    height: dp(90)
                    spacing: dp(14)
                    padding: dp(14)
                    canvas.before:
                        Color:
                            rgba: get_color_from_hex('#1E2E3E')
                        RoundedRectangle:
                            size: self.size
                            pos: self.pos
                            radius: [dp(14)]
                    Button:
                        size_hint: None, None
                        size: dp(52), dp(52)
                        pos_hint: {'center_y': 0.5}
                        background_normal: ''
                        background_color: get_color_from_hex('#6BCB77')
                        color: get_color_from_hex('#FFFFFF')
                        font_size: dp(22)
                        bold: True
                        text: 'Я'
                    BoxLayout:
                        orientation: 'vertical'
                        spacing: dp(4)
                        Label:
                            text: 'Гость'
                            font_size: dp(18)
                            bold: True
                            color: get_color_from_hex('#FFFFFF')
                            halign: 'left'
                            text_size: self.size
                            valign: 'bottom'
                        Label:
                            text: 'Гостевой аккаунт' if root.is_guest else 'Зарегистрирован'
                            font_size: dp(13)
                            color: get_color_from_hex('#A8C5DA')
                            halign: 'left'
                            text_size: self.size
                            valign: 'top'

                # Войти / Регистрация
                BoxLayout:
                    size_hint_y: None
                    height: dp(50) if root.is_guest else dp(0)
                    spacing: dp(10)
                    opacity: 1 if root.is_guest else 0
                    Button:
                        text: 'Войти'
                        background_normal: ''
                        background_color: get_color_from_hex('#6BCB77')
                        color: get_color_from_hex('#FFFFFF')
                        font_size: dp(15)
                        bold: True
                        on_release: app.root.current = 'login'
                    Button:
                        text: 'Регистрация'
                        background_normal: ''
                        background_color: get_color_from_hex('#1B4D3E')
                        color: get_color_from_hex('#6BCB77')
                        font_size: dp(15)
                        bold: True
                        on_release: app.root.current = 'login'

                Label:
                    text: 'БЕЗОПАСНОСТЬ'
                    font_size: dp(11)
                    bold: True
                    color: get_color_from_hex('#6BCB77')
                    halign: 'left'
                    text_size: self.size
                    size_hint_y: None
                    height: dp(22)

                BoxLayout:
                    size_hint_y: None
                    height: dp(50)
                    padding: [dp(14), dp(8)]
                    canvas.before:
                        Color:
                            rgba: get_color_from_hex('#1E2E3E')
                        RoundedRectangle:
                            size: self.size
                            pos: self.pos
                            radius: [dp(12)]
                    Label:
                        text: 'Touch ID / PIN-код'
                        font_size: dp(14)
                        color: get_color_from_hex('#FFFFFF')
                        halign: 'left'
                        text_size: self.size
                    Button:
                        size_hint_x: None
                        width: dp(80)
                        text: 'Задать'
                        font_size: dp(12)
                        bold: True
                        background_normal: ''
                        background_color: get_color_from_hex('#1B4D3E')
                        color: get_color_from_hex('#6BCB77')
                        on_release: root.set_pin()

                BoxLayout:
                    size_hint_y: None
                    height: dp(40)
                    padding: [dp(14), dp(6)]
                    canvas.before:
                        Color:
                            rgba: get_color_from_hex('#162030')
                        RoundedRectangle:
                            size: self.size
                            pos: self.pos
                            radius: [dp(10)]
                    Label:
                        text: 'Ваши данные защищены. Личные данные никто не видит.'
                        font_size: dp(11)
                        color: get_color_from_hex('#A8C5DA')
                        halign: 'left'
                        text_size: self.size

                Label:
                    text: 'ОСНОВНОЕ'
                    font_size: dp(11)
                    bold: True
                    color: get_color_from_hex('#6BCB77')
                    halign: 'left'
                    text_size: self.size
                    size_hint_y: None
                    height: dp(22)

                BoxLayout:
                    size_hint_y: None
                    height: dp(50)
                    padding: [dp(14), dp(8)]
                    canvas.before:
                        Color:
                            rgba: get_color_from_hex('#1E2E3E')
                        RoundedRectangle:
                            size: self.size
                            pos: self.pos
                            radius: [dp(12)]
                    Label:
                        text: 'Сменить язык'
                        font_size: dp(14)
                        color: get_color_from_hex('#FFFFFF')
                        halign: 'left'
                        text_size: self.size
                    Label:
                        text: 'RU'
                        font_size: dp(14)
                        bold: True
                        color: get_color_from_hex('#A8C5DA')
                        halign: 'right'
                        text_size: self.size

                BoxLayout:
                    size_hint_y: None
                    height: dp(50)
                    padding: [dp(14), dp(8)]
                    canvas.before:
                        Color:
                            rgba: get_color_from_hex('#1E2E3E')
                        RoundedRectangle:
                            size: self.size
                            pos: self.pos
                            radius: [dp(12)]
                    Label:
                        text: 'Темная тема'
                        font_size: dp(14)
                        color: get_color_from_hex('#FFFFFF')
                        halign: 'left'
                        text_size: self.size
                    Switch:
                        size_hint_x: None
                        width: dp(60)
                        active: root.dark_mode
                        on_active: root.toggle_dark(self.active)

                BoxLayout:
                    size_hint_y: None
                    height: dp(50)
                    padding: [dp(14), dp(8)]
                    canvas.before:
                        Color:
                            rgba: get_color_from_hex('#1E2E3E')
                        RoundedRectangle:
                            size: self.size
                            pos: self.pos
                            radius: [dp(12)]
                    Label:
                        text: 'Уведомления на экране'
                        font_size: dp(13)
                        color: get_color_from_hex('#FFFFFF')
                        halign: 'left'
                        text_size: self.size
                    Switch:
                        size_hint_x: None
                        width: dp(60)
                        active: root.notif_screen
                        on_active: root.toggle_notif_screen(self.active)

                BoxLayout:
                    size_hint_y: None
                    height: dp(50)
                    padding: [dp(14), dp(8)]
                    canvas.before:
                        Color:
                            rgba: get_color_from_hex('#1E2E3E')
                        RoundedRectangle:
                            size: self.size
                            pos: self.pos
                            radius: [dp(12)]
                    Label:
                        text: 'Уведомления'
                        font_size: dp(14)
                        color: get_color_from_hex('#FFFFFF')
                        halign: 'left'
                        text_size: self.size
                    Switch:
                        size_hint_x: None
                        width: dp(60)
                        active: root.notif_enabled
                        on_active: root.toggle_notif(self.active)

                Label:
                    text: 'ДРУГОЕ'
                    font_size: dp(11)
                    bold: True
                    color: get_color_from_hex('#6BCB77')
                    halign: 'left'
                    text_size: self.size
                    size_hint_y: None
                    height: dp(22)

                Button:
                    text: 'Пригласить друзей'
                    size_hint_y: None
                    height: dp(50)
                    background_normal: ''
                    background_color: get_color_from_hex('#1E3A5F')
                    color: get_color_from_hex('#FFFFFF')
                    font_size: dp(14)
                    on_release: root.invite_friends()

                Button:
                    text: 'Удалить профиль'
                    size_hint_y: None
                    height: dp(50)
                    background_normal: ''
                    background_color: get_color_from_hex('#2A1010')
                    color: get_color_from_hex('#E74C3C')
                    font_size: dp(14)
                    on_release: root.delete_profile()

                Label:
                    text: 'Личные данные никто не видит.\nВы можете в любой момент удалить профиль.'
                    font_size: dp(11)
                    color: get_color_from_hex('#A8C5DA')
                    halign: 'center'
                    size_hint_y: None
                    height: dp(44)

                Widget:
                    size_hint_y: None
                    height: dp(20)
